# Autodesk Platform Services (APS) Credentials
# Get these from https://aps.autodesk.com → Applications → Create Application
APS_CLIENT_ID=your_client_id_here
APS_CLIENT_SECRET=your_client_secret_here

# OAuth Callback URL (must match what you set in APS app settings)
APS_CALLBACK_URL=http://localhost:8080/api/auth/callback

# Server port
PORT=8080

# Forma API Region (us or eu)
FORMA_REGION=us
